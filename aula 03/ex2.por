programa {
  funcao inicio() {

    real idade 

    escreva("informe a idade:") 
    leia(idade)

    se (idade>= 65) {
      escreva("você é um idoso")
    }

    se (idade>= 18) {
      escreva("você é um adulto")
    }

    se (idade>= 13) {
      escreva("você é um adolecente")
    }



    
  }
}
